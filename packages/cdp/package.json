{
  "name": "@josharsh/pixelpi-cdp",
  "version": "0.2.1",
  "description": "Thin Chrome DevTools Protocol transport powering pixelpi's pixel-cheap look() over raw CDP.",
  "type": "module",
  "types": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josharsh/pixelpi.git",
    "directory": "packages/cdp"
  },
  "homepage": "https://github.com/josharsh/pixelpi#readme",
  "bugs": {
    "url": "https://github.com/josharsh/pixelpi/issues"
  },
  "keywords": [
    "browser-agent",
    "cdp",
    "llm",
    "ai-agent",
    "playwright-alternative",
    "browser-automation",
    "cli",
    "typescript",
    "chrome-devtools-protocol"
  ],
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@josharsh/pixelpi-core": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
