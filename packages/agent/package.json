{
  "name": "pixelpi",
  "version": "0.1.6",
  "description": "pi for the browser: a minimal browser-agent CLI and harness over raw Chrome DevTools Protocol, any model.",
  "type": "module",
  "types": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "bin": {
    "pixelpi": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josharsh/pixelpi.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/josharsh/pixelpi#readme",
  "bugs": {
    "url": "https://github.com/josharsh/pixelpi/issues"
  },
  "keywords": [
    "browser-agent",
    "cdp",
    "llm",
    "ai-agent",
    "playwright-alternative",
    "browser-automation",
    "cli",
    "typescript",
    "chrome-devtools-protocol"
  ],
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@josharsh/pixelpi-ai": "workspace:*",
    "@josharsh/pixelpi-cdp": "workspace:*",
    "@josharsh/pixelpi-core": "workspace:*"
  }
}
