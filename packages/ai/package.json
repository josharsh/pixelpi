{
  "name": "@josharsh/pixelpi-ai",
  "version": "0.1.0",
  "description": "Model-agnostic LLM client for the pixelpi browser agent (Anthropic + OpenAI).",
  "type": "module",
  "types": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josharsh/pixelpi.git",
    "directory": "packages/ai"
  },
  "homepage": "https://github.com/josharsh/pixelpi#readme",
  "bugs": {
    "url": "https://github.com/josharsh/pixelpi/issues"
  },
  "keywords": [
    "browser-agent",
    "cdp",
    "llm",
    "ai-agent",
    "playwright-alternative",
    "browser-automation",
    "cli",
    "typescript",
    "chrome-devtools-protocol"
  ],
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "openai": "^6.44.0"
  }
}
