{
  "name": "pixelpi-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "pixelpi": "tsx packages/agent/src/cli.ts",
    "bench:tokens": "tsx bench/efficiency.ts",
    "bench:tasks": "tsx bench/tasks.ts",
    "release": "pnpm -r build && pnpm -r publish --access public --no-git-checks",
    "check:publish": "pnpm -r --filter './packages/*' exec publint"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@josharsh/pixelpi-ai": "workspace:*",
    "@josharsh/pixelpi-cdp": "workspace:*",
    "@josharsh/pixelpi-core": "workspace:*",
    "@types/node": "^22.19.21",
    "pixelpi": "workspace:*",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
